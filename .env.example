# Client configuration. For a physical phone, replace localhost with your
# computer's LAN address, for example http://192.168.1.10:4000/api.
EXPO_PUBLIC_API_URL=http://localhost:4000/api

# Backend configuration. Copy this file to .env and keep it private. Use either
# one complete MONGODB_URI or the individual MONGO_* fields below.
MONGODB_URI=
MONGO_USERNAME=your-database-user
MONGO_PASSWORD=your-database-password
MONGO_PORT=27017
MONGO_NAME=fitplan
MONGO_HOST=your-cluster.mongodb.net

JWT_SECRET=replace-with-at-least-32-random-characters
PORT=4000
CLIENT_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:19006

# Comma-separated accounts that should receive the admin role.
ADMIN_EMAILS=

# Server-side AI coach (fitness-only). Keys are ONLY read on the server — never
# prefix an AI key with EXPO_PUBLIC_, that would ship it to the browser/app.
#
# OpenAI is tried first with a low-cost model. Note: the OpenAI API has no free
# tier, but gpt-4o-mini is very cheap; gpt-4.1-nano is cheaper still.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional fallback provider, used automatically if OpenAI is rate-limited or
# out of quota. Leave blank to disable the fallback.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Provider preference: "auto" (default) tries OpenAI then Anthropic;
# set to "anthropic" to prefer Claude first.
AI_PROVIDER=auto
