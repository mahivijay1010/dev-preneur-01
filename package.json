{
  "name": "fitplan",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "npm run start:frontend",
    "dev": "concurrently -n API,APP -c yellow,cyan \"npm run start:dev\" \"npm run start:frontend\"",
    "dev:device": "concurrently -n API,APP -c yellow,cyan \"npm run start:dev\" \"expo start --lan\"",
    "dev:device:tunnel": "concurrently -n API,APP -c yellow,cyan \"npm run start:dev\" \"expo start --tunnel\"",
    "start:frontend": "expo start --web --host localhost --port 3000",
    "start:backend": "node server/index.js",
    "start:dev": "nodemon --config nodemon.json server/index.js",
    "server": "npm run start:backend",
    "server:dev": "npm run start:dev",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "npm run start:frontend",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "verify:web": "node scripts/verify-ui.mjs"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "expo": "~51.0.28",
    "expo-constants": "~16.0.2",
    "expo-image-picker": "~15.1.0",
    "expo-linking": "~6.3.1",
    "expo-notifications": "~0.28.16",
    "expo-router": "~3.5.23",
    "expo-status-bar": "~1.12.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react-native": "^0.468.0",
    "mongoose": "^8.16.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0",
    "react-native-web": "~0.19.10",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~18.2.79",
    "concurrently": "^9.2.0",
    "nodemon": "^3.1.14",
    "playwright-core": "^1.61.1",
    "typescript": "~5.3.3"
  },
  "private": true
}
